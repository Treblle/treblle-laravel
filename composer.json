{
    "name": "treblle/treblle-laravel",
    "description": "Runtime Intelligence Platform",
    "version": "6.1.0",
    "license": "MIT",
    "homepage": "https://treblle.com/",
    "type": "library",
    "keywords": [
        "treblle",
        "intelligence",
        "runtime",
        "monitoring",
        "observability",
        "laravel",
        "php",
        "analytics",
        "governance",
        "logs"
    ],
    "authors": [
        {
            "role": "Developer",
            "name": "Vedran Cindric",
            "email": "vedran@treblle.com",
            "homepage": "https://treblle.com/"
        }
    ],
    "autoload": {
        "psr-4": {
            "Treblle\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Treblle\\Laravel\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-zlib": "*",
        "guzzlehttp/guzzle": "^7.4"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
        "laravel/pint": "^1.15"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Treblle\\Laravel\\TreblleServiceProvider"
            ],
            "aliases": {
                "Treblle": "Treblle\\Laravel\\Facades\\Treblle"
            }
        }
    },
    "scripts": {
        "pint": [
            "./vendor/bin/pint"
        ],
        "stan": [
            "./vendor/bin/phpstan analyse"
        ],
        "test": [
            "./vendor/bin/phpunit"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    }
}
